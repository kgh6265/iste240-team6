<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Event</title>
    <style>
        body { margin: 0 auto; max-width: 600px; font-family: sans-serif; }
        h1 { color: blue; }
        label { display: block; margin-top: 12px; font-weight: bold; }
        input, select { width: 100%; padding: 8px; margin-top: 4px; box-sizing: border-box; }
        button { margin-top: 20px; padding: 10px 20px; background-color: blue; color: white; border: none; cursor: pointer; }
        a { display: inline-block; margin-top: 16px; color: blue; }
    </style>
</head>
<body>
<h1>Add New Event</h1>
<form method="post" action="/events/add">
    <label>ID</label>
    <input type="text" name="id" placeholder="e.g. 002" required>

    <label>Title</label>
    <input type="text" name="title" placeholder="Event title" required>

    <label>Description</label>
    <input type="text" name="description" placeholder="Short description">

    <label>Category</label>
    <input type="text" name="category" placeholder="e.g. SG, Academic, Social">

    <label>Status</label>
    <select name="status">
        <option value="PENDING">Pending</option>
        <option value="IN_PROGRESS">In Progress</option>
        <option value="COMPLETED">Completed</option>
    </select>

    <button type="submit">Add Event</button>
</form>
<a href="/events">← Back to Events</a><br>
<a href="/">← Back to Home</a>
</body>
</html>
