<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Comment</title>
    <style>
        body { margin: 0 auto; max-width: 600px; font-family: sans-serif; }
        h1 { color: blue; }
        label { display: block; margin-top: 12px; font-weight: bold; }
        input, select, textarea { width: 100%; padding: 8px; margin-top: 4px; box-sizing: border-box; }
        button { margin-top: 20px; padding: 10px 20px; background-color: blue; color: white; border: none; cursor: pointer; }
        a { display: inline-block; margin-top: 16px; color: blue; }
    </style>
</head>
<body>
<h1>Add New Comment</h1>
<form method="post" action="/comments/add">
    <label>ID</label>
    <input type="text" name="id" placeholder="e.g. C002" required>

    <label>Event ID</label>
    <input type="text" name="eventid" placeholder="e.g. E001" required>

    <label>Student ID</label>
    <input type="text" name="studentid" placeholder="e.g. 412002594" required>

    <label>Content</label>
    <textarea name="content" placeholder="Type your comment..." rows="4" required></textarea>

    <button type="submit">Add Comment</button>
</form>
<a href="/comments">← Back to Comments</a><br>
<a href="/">← Back to Home</a>
</body>
</html>
